# MongoDB
MONGODB_URI=mongodb://localhost:27017/careapp
MONGODB_USER=careapp_user
MONGODB_PASSWORD=secure_password_123

# Server
PORT=5001
NODE_ENV=development
HOST=localhost

# JWT
JWT_SECRET=my_super_secret_key_12345
JWT_EXPIRATION=30d

# Email (اختياري)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Frontend URLs (CORS)
FRONTEND_URL=http://localhost:3000
MOBILE_URL=http://localhost:8100

# API Config
API_VERSION=v1
API_PREFIX=/api

# Logging
LOG_LEVEL=debug
